{
  "rules": {
    "auction": {
      "current": {
        ".read": true,
        ".write": true,
        "status": {
          ".validate": "newData.val() === 'draft' || newData.val() === 'live' || newData.val() === 'ended'"
        },
        "currentPriceCents": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "startingPriceCents": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "lastBidAmountCents": {
          ".validate": "newData.isNumber() && (newData.val() === 0 || newData.val() === 1 || newData.val() === 3 || newData.val() === 5 || newData.val() === 10)"
        },
        "accessCode": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 30"
        },
        "participants": {
          "$participantId": {
            "id": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
            },
            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 30"
            },
            "active": {
              ".validate": "newData.isBoolean()"
            },
            "joinedAt": {
              ".validate": "newData.exists()"
            },
            "lastSeenAt": {
              ".validate": "newData.isNumber()"
            },
            "$other": {
              ".validate": true
            }
          }
        },
        "bidHistory": {
          "$bidId": {
            "participantId": {
              ".validate": "newData.isString() && newData.val().length > 0"
            },
            "participantName": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 30"
            },
            "amountCents": {
              ".validate": "newData.isNumber() && (newData.val() === 1 || newData.val() === 3 || newData.val() === 5 || newData.val() === 10)"
            },
            "newPriceCents": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "timestamp": {
              ".validate": "newData.isNumber()"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "$other": {
          ".validate": true
        }
      }
    }
  }
}
